# Chọn 1 trong 3 provider bên dưới, bỏ comment dòng tương ứng
# Sao chép file này thành .env:  cp .env.example .env

# ════════════════════════════════════════════════════════
# CÁCH 1: Gemini Flash – MIỄN PHÍ (khuyên dùng)
# Lấy key tại: https://aistudio.google.com  (đăng nhập Google)
# Giới hạn miễn phí: 1500 request/ngày, 15 request/phút
# ════════════════════════════════════════════════════════
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIza-your-key-here

# ════════════════════════════════════════════════════════
# CÁCH 2: Ollama – HOÀN TOÀN MIỄN PHÍ (chạy local)
# Cài Ollama: https://ollama.com/download
# Sau đó chạy: ollama pull qwen2.5:3b
# Không cần internet khi chạy game
# ════════════════════════════════════════════════════════
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=qwen2.5:3b
# OLLAMA_URL=http://localhost:11434

# ════════════════════════════════════════════════════════
# CÁCH 3: Claude Haiku – Trả phí (~$0.0001/ván)
# Lấy key tại: https://console.anthropic.com
# ════════════════════════════════════════════════════════
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Nếu không cấu hình gì → game vẫn chạy với rule-based text (không lỗi)
